{
  "name": "vscode-hetzner-cloud",
  "displayName": "Hetzner Cloud Toolkit",
  "description": "Manage Hetzner Cloud infrastructure directly from VS Code — servers, networks, SSH keys, Tailscale and more",
  "version": "0.2.1",
  "publisher": "brwinnov.vsce",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "hetzner",
    "cloud",
    "vps",
    "server",
    "tailscale",
    "infrastructure"
  ],
  "icon": "resources/icon.png",
  "license": "MIT",
  "homepage": "https://github.com/brwinnov/vscode-hetzner-cloud#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brwinnov/vscode-hetzner-cloud.git"
  },
  "bugs": {
    "url": "https://github.com/brwinnov/vscode-hetzner-cloud/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "galleryBanner": {
    "color": "#D50C2D",
    "theme": "dark"
  },
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hcloud.welcome",
        "title": "Hetzner Cloud: Open Welcome Page",
        "icon": "$(home)"
      },
      {
        "command": "hcloud.cloudConsole",
        "title": "Hetzner Cloud: Cloud Console (Coming Soon)",
        "icon": "$(globe)"
      },
      {
        "command": "hcloud.addToken",
        "title": "Hetzner Cloud: Add API Token",
        "icon": "$(add)"
      },
      {
        "command": "hcloud.removeToken",
        "title": "Hetzner Cloud: Remove API Token"
      },
      {
        "command": "hcloud.switchToken",
        "title": "Hetzner Cloud: Switch Active Project"
      },
      {
        "command": "hcloud.refreshServers",
        "title": "Hetzner Cloud: Refresh Servers",
        "icon": "$(refresh)"
      },
      {
        "command": "hcloud.createServer",
        "title": "Hetzner Cloud: Create Server",
        "icon": "$(add)"
      },
      {
        "command": "hcloud.startServer",
        "title": "Hetzner Cloud: Start Server",
        "icon": "$(play)"
      },
      {
        "command": "hcloud.stopServer",
        "title": "Hetzner Cloud: Stop Server",
        "icon": "$(debug-stop)"
      },
      {
        "command": "hcloud.rebootServer",
        "title": "Hetzner Cloud: Reboot Server",
        "icon": "$(debug-restart)"
      },
      {
        "command": "hcloud.deleteServer",
        "title": "Hetzner Cloud: Delete Server",
        "icon": "$(trash)"
      },
      {
        "command": "hcloud.showServerDetail",
        "title": "Hetzner Cloud: Show Server Details",
        "icon": "$(info)"
      },
      {
        "command": "hcloud.sshServer",
        "title": "Hetzner Cloud: Open SSH Terminal",
        "icon": "$(terminal)"
      },
      {
        "command": "hcloud.refreshNetworks",
        "title": "Hetzner Cloud: Refresh Networks",
        "icon": "$(refresh)"
      },
      {
        "command": "hcloud.createNetwork",
        "title": "Hetzner Cloud: Create Network",
        "icon": "$(add)"
      },
      {
        "command": "hcloud.refreshImages",
        "title": "Hetzner Cloud: Refresh Images",
        "icon": "$(refresh)"
      },
      {
        "command": "hcloud.refreshSshKeys",
        "title": "Hetzner Cloud: Refresh SSH Keys",
        "icon": "$(refresh)"
      },
      {
        "command": "hcloud.addSshKey",
        "title": "Hetzner Cloud: Add SSH Key",
        "icon": "$(add)"
      },
      {
        "command": "hcloud.setTailscaleKey",
        "title": "Hetzner Cloud: Set Tailscale Auth Key"
      },
      {
        "command": "hcloud.refreshProjects",
        "title": "Hetzner Cloud: Refresh Projects",
        "icon": "$(refresh)"
      },
      {
        "command": "hcloud.removeProject",
        "title": "Hetzner Cloud: Remove Project",
        "icon": "$(trash)"
      },
      {
        "command": "hcloud.activateProject",
        "title": "Hetzner Cloud: Activate Project",
        "icon": "$(check)"
      },
      {
        "command": "hcloud.deleteNetwork",
        "title": "Hetzner Cloud: Delete Network",
        "icon": "$(trash)"
      },
      {
        "command": "hcloud.addSubnet",
        "title": "Hetzner Cloud: Add Subnet",
        "icon": "$(add)"
      },
      {
        "command": "hcloud.addSubnetToNetwork",
        "title": "Hetzner Cloud: Add Subnet to Network",
        "icon": "$(add)"
      },
      {
        "command": "hcloud.showNetworkDetail",
        "title": "Hetzner Cloud: Show Network Details",
        "icon": "$(info)"
      },
      {
        "command": "hcloud.deleteSubnet",
        "title": "Hetzner Cloud: Remove Subnet",
        "icon": "$(trash)"
      },
      {
        "command": "hcloud.sshKeyGuide",
        "title": "Hetzner Cloud: SSH Key Generation Guide",
        "icon": "$(book)"
      },
      {
        "command": "hcloud.deleteSshKey",
        "title": "Hetzner Cloud: Remove SSH Key",
        "icon": "$(trash)"
      },
      {
        "command": "hcloud.refreshFirewalls",
        "title": "Hetzner Cloud: Refresh Firewalls",
        "icon": "$(refresh)"
      },
      {
        "command": "hcloud.createFirewall",
        "title": "Hetzner Cloud: Create Firewall",
        "icon": "$(add)"
      },
      {
        "command": "hcloud.deleteFirewall",
        "title": "Hetzner Cloud: Delete Firewall",
        "icon": "$(trash)"
      },
      {
        "command": "hcloud.addFirewallRule",
        "title": "Hetzner Cloud: Add Firewall Rule",
        "icon": "$(add)"
      },
      {
        "command": "hcloud.deleteFirewallRule",
        "title": "Hetzner Cloud: Delete Firewall Rule",
        "icon": "$(trash)"
      },
      {
        "command": "hcloud.applyFirewallToServer",
        "title": "Hetzner Cloud: Apply Firewall to Server",
        "icon": "$(vm)"
      },
      {
        "command": "hcloud.removeFirewallFromServer",
        "title": "Hetzner Cloud: Remove Firewall from Server",
        "icon": "$(close)"
      },
      {
        "command": "hcloud.refreshVolumes",
        "title": "Hetzner Cloud: Refresh Volumes",
        "icon": "$(refresh)"
      },
      {
        "command": "hcloud.createVolume",
        "title": "Hetzner Cloud: Create Volume",
        "icon": "$(add)"
      },
      {
        "command": "hcloud.deleteVolume",
        "title": "Hetzner Cloud: Delete Volume",
        "icon": "$(trash)"
      },
      {
        "command": "hcloud.attachVolume",
        "title": "Hetzner Cloud: Attach Volume to Server",
        "icon": "$(vm)"
      },
      {
        "command": "hcloud.detachVolume",
        "title": "Hetzner Cloud: Detach Volume from Server",
        "icon": "$(close)"
      },
      {
        "command": "hcloud.resizeVolume",
        "title": "Hetzner Cloud: Resize Volume",
        "icon": "$(arrow-up)"
      },
      {
        "command": "hcloud.setRobotCredentials",
        "title": "Hetzner Cloud: Set Robot API Credentials",
        "icon": "$(key)"
      },
      {
        "command": "hcloud.clearRobotCredentials",
        "title": "Hetzner Cloud: Clear Robot API Credentials",
        "icon": "$(trash)"
      },
      {
        "command": "hcloud.refreshStorageBoxes",
        "title": "Hetzner Cloud: Refresh Storage Boxes",
        "icon": "$(refresh)"
      },
      {
        "command": "hcloud.mountStorageBoxToServer",
        "title": "Hetzner Cloud: Mount Storage Box to Server",
        "icon": "$(vm-connect)"
      },
      {
        "command": "hcloud.copyStorageBoxMountCommands",
        "title": "Hetzner Cloud: Copy Mount Commands to Clipboard",
        "icon": "$(clippy)"
      },
      {
        "command": "hcloud.createLoadBalancer",
        "title": "Hetzner Cloud: Create Load Balancer",
        "icon": "$(add)"
      },
      {
        "command": "hcloud.deleteLoadBalancer",
        "title": "Hetzner Cloud: Delete Load Balancer",
        "icon": "$(trash)"
      },
      {
        "command": "hcloud.addLoadBalancerTarget",
        "title": "Hetzner Cloud: Add Target to Load Balancer",
        "icon": "$(vm)"
      },
      {
        "command": "hcloud.removeLoadBalancerTarget",
        "title": "Hetzner Cloud: Remove Target from Load Balancer",
        "icon": "$(close)"
      },
      {
        "command": "hcloud.refreshLoadBalancers",
        "title": "Hetzner Cloud: Refresh Load Balancers",
        "icon": "$(refresh)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hetzner-cloud-toolkit",
          "title": "Hetzner Cloud Toolkit",
          "icon": "resources/hcloud.svg"
        }
      ]
    },
    "views": {
      "hetzner-cloud-toolkit": [
        {
          "id": "hcloud.setup",
          "name": "Setup",
          "initialSize": 1
        },
        {
          "id": "hcloud.projects",
          "name": "Projects",
          "initialSize": 1
        },
        {
          "id": "hcloud.servers",
          "name": "Servers",
          "initialSize": 2
        },
        {
          "id": "hcloud.networks",
          "name": "Networks",
          "initialSize": 2
        },
        {
          "id": "hcloud.images",
          "name": "Images",
          "initialSize": 2
        },
        {
          "id": "hcloud.sshKeys",
          "name": "SSH Keys",
          "initialSize": 2
        },
        {
          "id": "hcloud.firewalls",
          "name": "Firewalls",
          "initialSize": 2
        },
        {
          "id": "hcloud.volumes",
          "name": "Volumes",
          "initialSize": 2
        },
        {
          "id": "hcloud.storageBoxes",
          "name": "Storage Boxes",
          "initialSize": 2
        },
        {
          "id": "hcloud.loadBalancers",
          "name": "Load Balancers",
          "initialSize": 2
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "hcloud.refreshProjects",
          "when": "view == hcloud.projects",
          "group": "navigation"
        },
        {
          "command": "hcloud.createServer",
          "when": "view == hcloud.servers",
          "group": "navigation"
        },
        {
          "command": "hcloud.refreshServers",
          "when": "view == hcloud.servers",
          "group": "navigation"
        },
        {
          "command": "hcloud.createNetwork",
          "when": "view == hcloud.networks",
          "group": "navigation"
        },
        {
          "command": "hcloud.refreshNetworks",
          "when": "view == hcloud.networks",
          "group": "navigation"
        },
        {
          "command": "hcloud.addSubnetToNetwork",
          "when": "view == hcloud.networks",
          "group": "navigation"
        },
        {
          "command": "hcloud.addSshKey",
          "when": "view == hcloud.sshKeys",
          "group": "navigation"
        },
        {
          "command": "hcloud.sshKeyGuide",
          "when": "view == hcloud.sshKeys",
          "group": "navigation"
        },
        {
          "command": "hcloud.refreshSshKeys",
          "when": "view == hcloud.sshKeys",
          "group": "navigation"
        },
        {
          "command": "hcloud.refreshImages",
          "when": "view == hcloud.images",
          "group": "navigation"
        },
        {
          "command": "hcloud.createFirewall",
          "when": "view == hcloud.firewalls",
          "group": "navigation"
        },
        {
          "command": "hcloud.refreshFirewalls",
          "when": "view == hcloud.firewalls",
          "group": "navigation"
        },
        {
          "command": "hcloud.createVolume",
          "when": "view == hcloud.volumes",
          "group": "navigation"
        },
        {
          "command": "hcloud.refreshVolumes",
          "when": "view == hcloud.volumes",
          "group": "navigation"
        },
        {
          "command": "hcloud.setRobotCredentials",
          "when": "view == hcloud.storageBoxes",
          "group": "navigation"
        },
        {
          "command": "hcloud.refreshStorageBoxes",
          "when": "view == hcloud.storageBoxes",
          "group": "navigation"
        },
        {
          "command": "hcloud.createLoadBalancer",
          "when": "view == hcloud.loadBalancers",
          "group": "navigation"
        },
        {
          "command": "hcloud.refreshLoadBalancers",
          "when": "view == hcloud.loadBalancers",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "hcloud.activateProject",
          "when": "view == hcloud.projects && viewItem == project-inactive",
          "group": "1_project@1"
        },
        {
          "command": "hcloud.removeProject",
          "when": "view == hcloud.projects",
          "group": "9_danger@1"
        },
        {
          "command": "hcloud.startServer",
          "when": "view == hcloud.servers && viewItem == server-off",
          "group": "1_server@1"
        },
        {
          "command": "hcloud.stopServer",
          "when": "view == hcloud.servers && viewItem == server-on",
          "group": "1_server@2"
        },
        {
          "command": "hcloud.rebootServer",
          "when": "view == hcloud.servers && viewItem == server-on",
          "group": "1_server@3"
        },
        {
          "command": "hcloud.sshServer",
          "when": "view == hcloud.servers && viewItem == server-on",
          "group": "1_server@4"
        },
        {
          "command": "hcloud.showServerDetail",
          "when": "view == hcloud.servers",
          "group": "1_server@5"
        },
        {
          "command": "hcloud.deleteServer",
          "when": "view == hcloud.servers",
          "group": "9_danger@1"
        },
        {
          "command": "hcloud.deleteNetwork",
          "when": "view == hcloud.networks && viewItem == network",
          "group": "9_danger@1"
        },
        {
          "command": "hcloud.addSubnet",
          "when": "view == hcloud.networks && viewItem == network",
          "group": "1_network@1"
        },
        {
          "command": "hcloud.deleteSubnet",
          "when": "view == hcloud.networks && viewItem == subnet",
          "group": "9_danger@1"
        },
        {
          "command": "hcloud.deleteSshKey",
          "when": "view == hcloud.sshKeys && viewItem == sshkey",
          "group": "9_danger@1"
        },
        {
          "command": "hcloud.addFirewallRule",
          "when": "view == hcloud.firewalls && viewItem == firewall",
          "group": "1_firewall@1"
        },
        {
          "command": "hcloud.applyFirewallToServer",
          "when": "view == hcloud.firewalls && viewItem == firewall",
          "group": "1_firewall@2"
        },
        {
          "command": "hcloud.removeFirewallFromServer",
          "when": "view == hcloud.firewalls && viewItem == firewall",
          "group": "1_firewall@3"
        },
        {
          "command": "hcloud.deleteFirewall",
          "when": "view == hcloud.firewalls && viewItem == firewall",
          "group": "9_danger@1"
        },
        {
          "command": "hcloud.deleteFirewallRule",
          "when": "view == hcloud.firewalls && viewItem == firewall-rule",
          "group": "9_danger@1"
        },
        {
          "command": "hcloud.attachVolume",
          "when": "view == hcloud.volumes && viewItem == volume-detached",
          "group": "1_volume@1"
        },
        {
          "command": "hcloud.detachVolume",
          "when": "view == hcloud.volumes && viewItem == volume-attached",
          "group": "1_volume@1"
        },
        {
          "command": "hcloud.resizeVolume",
          "when": "view == hcloud.volumes && (viewItem == volume-attached || viewItem == volume-detached)",
          "group": "1_volume@2"
        },
        {
          "command": "hcloud.deleteVolume",
          "when": "view == hcloud.volumes && viewItem == volume-detached",
          "group": "9_danger@1"
        },
        {
          "command": "hcloud.mountStorageBoxToServer",
          "when": "view == hcloud.storageBoxes && viewItem == storagebox",
          "group": "1_storagebox@1"
        },
        {
          "command": "hcloud.copyStorageBoxMountCommands",
          "when": "view == hcloud.storageBoxes && viewItem == storagebox",
          "group": "1_storagebox@2"
        },
        {
          "command": "hcloud.addLoadBalancerTarget",
          "when": "view == hcloud.loadBalancers && viewItem == loadbalancer",
          "group": "1_lb@1"
        },
        {
          "command": "hcloud.removeLoadBalancerTarget",
          "when": "view == hcloud.loadBalancers && viewItem == lb-target",
          "group": "9_danger@1"
        },
        {
          "command": "hcloud.deleteLoadBalancer",
          "when": "view == hcloud.loadBalancers && viewItem == loadbalancer",
          "group": "9_danger@2"
        }
      ]
    },
    "configuration": {
      "title": "Hetzner Cloud Toolkit",
      "properties": {
        "hcloud.tailscale.enableByDefault": {
          "type": "boolean",
          "default": true,
          "description": "Automatically inject Tailscale installation into every cloud-init script."
        },
        "hcloud.tailscale.extraArgs": {
          "type": "string",
          "default": "--accept-routes --ssh",
          "description": "Extra arguments passed to `tailscale up` during cloud-init."
        },
        "hcloud.defaultRegion": {
          "type": "string",
          "default": "nbg1",
          "enum": [
            "nbg1",
            "fsn1",
            "hel1",
            "ash",
            "hil"
          ],
          "description": "Default datacenter location for new servers."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:prod",
    "build": "node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "package": "npx vsce package",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-cli": "^0.0.6",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.0"
  }
}
